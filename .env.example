# Supabase → Project Settings → API
# URL: Project URL
# Key: anon public (JWT, odatda eyJ bilan boshlanadi)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-jwt-key

# Click to'lovi (ochiq ma'lumot — havola uchun; SECRET_KEY faqat Supabase Edge Functions secrets da)
VITE_CLICK_MERCHANT_ID=
VITE_CLICK_SERVICE_ID=
VITE_CLICK_MERCHANT_USER_ID=
